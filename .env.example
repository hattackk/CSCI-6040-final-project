# fitd_repro environment configuration.
# Copy to ".env" and fill in only the variables you need for the scenario
# you're running. The roles (target, judge, assistant) are independent:
# unset role-specific vars fall back to the shared VLLM_* / OLLAMA_* pair.

# ---------------------------------------------------------------------------
# OpenAI (only required when opting a role into --backend openai)
# ---------------------------------------------------------------------------
# Paper-faithful defaults: judge = gpt-4o, assistant M = gpt-4o-mini.
OPENAI_API_KEY=
# Safety gate - the project refuses to hit OpenAI unless this is set to 1.
FITD_ALLOW_OPENAI=1

# ---------------------------------------------------------------------------
# vLLM target (--backend vllm): served by the "vllm" service in docker-compose.yml
# ---------------------------------------------------------------------------
HF_TOKEN=
VLLM_MODEL=meta-llama/Meta-Llama-3-8B-Instruct
VLLM_API_KEY=fitd-repro-target
VLLM_HOST_PORT=8001
VLLM_CUDA_DEVICE=0
VLLM_GPU_MEM_UTIL=0.85
VLLM_MAX_MODEL_LEN=4768
# VLLM_BASE_URL overrides the auto-derived http://localhost:${VLLM_HOST_PORT}/v1
# VLLM_BASE_URL=http://localhost:8001/v1

# ---------------------------------------------------------------------------
# vLLM judge (--judge-backend vllm): optional second container.
# Bring up with: docker compose --profile judge up -d vllm vllm-judge
# ---------------------------------------------------------------------------
VLLM_JUDGE_MODEL=Qwen/Qwen3.5-4B
VLLM_JUDGE_API_KEY=fitd-repro-judge
VLLM_JUDGE_HOST_PORT=8002
VLLM_JUDGE_CUDA_DEVICE=1
VLLM_JUDGE_GPU_MEM_UTIL=0.85
VLLM_JUDGE_MAX_MODEL_LEN=4768
# JUDGE_VLLM_BASE_URL overrides the auto-derived http://localhost:${VLLM_JUDGE_HOST_PORT}/v1
# JUDGE_VLLM_BASE_URL=http://localhost:8002/v1
# JUDGE_VLLM_API_KEY falls back to VLLM_API_KEY if unset
# JUDGE_VLLM_API_KEY=fitd-repro-judge

# ---------------------------------------------------------------------------
# vLLM assistant (--assistant-backend vllm): optional third container.
# Bring up with: docker compose --profile assistant up -d vllm vllm-assistant
# ---------------------------------------------------------------------------
VLLM_ASSISTANT_MODEL=Qwen/Qwen3.5-4B
VLLM_ASSISTANT_API_KEY=fitd-repro-assistant
VLLM_ASSISTANT_HOST_PORT=8003
VLLM_ASSISTANT_CUDA_DEVICE=1
VLLM_ASSISTANT_GPU_MEM_UTIL=0.85
VLLM_ASSISTANT_MAX_MODEL_LEN=4768
# ASSISTANT_VLLM_BASE_URL=http://localhost:8003/v1
# ASSISTANT_VLLM_API_KEY=fitd-repro-assistant

# ---------------------------------------------------------------------------
# Ollama (optional; per-role overrides)
# ---------------------------------------------------------------------------
# OLLAMA_HOST=http://127.0.0.1:11434
# JUDGE_OLLAMA_HOST=http://127.0.0.1:11434
# ASSISTANT_OLLAMA_HOST=http://127.0.0.1:11434
